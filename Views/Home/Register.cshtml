<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Register Employee</title>

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:'Segoe UI',sans-serif;
}

body{
background:linear-gradient(135deg,#4f46e5,#7c3aed,#ec4899);
min-height:100vh;
display:flex;
justify-content:center;
align-items:center;
padding:30px;
}

.card{
width:750px;
background:rgba(255,255,255,.15);
backdrop-filter:blur(15px);
padding:40px;
border-radius:25px;
box-shadow:0 20px 40px rgba(0,0,0,.2);
}

h1{
color:white;
text-align:center;
margin-bottom:10px;
font-size:38px;
}

h2{
color:white;
text-align:center;
margin-bottom:30px;
}

.form-group{
margin-bottom:20px;
}

label{
display:block;
color:white;
font-weight:600;
margin-bottom:8px;
}

input{
width:100%;
padding:15px;
border:none;
border-radius:12px;
font-size:15px;
}

input:focus{
outline:none;
}

.btn-container{
text-align:center;
margin-top:25px;
}

.btn{
background:white;
color:#4f46e5;
border:none;
padding:15px 35px;
font-size:17px;
font-weight:bold;
border-radius:12px;
cursor:pointer;
transition:.3s;
}

.btn:hover{
transform:translateY(-3px);
}

</style>
</head>

<body>

<div class="card">

<h1>👨‍💼 Welcome Admin</h1>

<h2>Register New Employee</h2>

<form method="POST">

<div class="form-group">
<label>Employee Id</label>
<input type="number" required name="Id">
</div>

<div class="form-group">
<label>Employee Name</label>
<input type="text" required name="Ename">
</div>

<div class="form-group">
<label>Employee Job</label>
<input type="text" name="Job">
</div>

<div class="form-group">
<label>Manager Id</label>
<input type="number" name="MGR">
</div>

<div class="form-group">
<label>Hire Date</label>
<input type="date" required name="HIREDATE">
</div>

<div class="form-group">
<label>Salary</label>
<input type="number" step="0.01" max="999900.99" name="SAL">
</div>

<div class="form-group">
<label>Commission</label>
<input type="number" step="0.01" max="9999.99" name="COMM">
</div>

<div class="form-group">
<label>Department Id</label>
<input type="number" name="DeptID">
</div>

<div class="btn-container">
<input type="submit" value="Register Employee" class="btn">
</div>

</form>

</div>

</body>
</html>S